// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// A department/team. Every board belongs to exactly one sector; members can
// only see and manage boards in their own sector, while admins see all.
model Sector {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  boards    Board[]
  createdAt DateTime @default(now())
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  // "admin" | "member". Admins have no sector and see everything; members
  // are scoped to exactly one sector.
  role          String
  sector        Sector?   @relation(fields: [sectorId], references: [id], onDelete: Restrict)
  sectorId      String?
  sessions      Session[]
  createdBoards Board[]
  createdAt     DateTime  @default(now())
}

// The cookie holds `token` (a random opaque value), never the row id, so a
// leaked/guessed database id can't be used to impersonate a session.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Board {
  id        String   @id @default(cuid())
  title     String
  accent    String   @default("blue")
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  sectorId  String
  // Nullable so a deleted user doesn't take their old boards down with them
  // (onDelete: SetNull) — a board with no creator can only be deleted by an
  // admin, never "adopted" by another member.
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  columns   Column[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectorId])
}

model Column {
  id               String            @id @default(cuid())
  title            String
  order            Int
  board            Board             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId          String
  cards            Card[]
  fieldDefinitions FieldDefinition[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([boardId, order])
}

model Card {
  id          String       @id @default(cuid())
  title       String
  order       Int
  column      Column       @relation(fields: [columnId], references: [id], onDelete: Cascade)
  columnId    String
  attachments Attachment[]
  fieldValues FieldValue[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([columnId, order])
}

model Attachment {
  id           String      @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  card         Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId       String
  fieldValue   FieldValue? @relation(fields: [fieldValueId], references: [id], onDelete: Cascade)
  fieldValueId String?
  createdAt    DateTime    @default(now())

  @@index([cardId])
  @@index([fieldValueId])
}

// A custom field defined on a column/stage (e.g. "Prioridade", a
// single-choice field with options ["Baixa","Media","Alta"]). Applies to
// every card while it sits in that column; values a card collected in a
// previous column remain attached to it as read-only history after it
// moves on, since FieldValue rows are never deleted on a move.
model FieldDefinition {
  id           String       @id @default(cuid())
  column       Column       @relation(fields: [columnId], references: [id], onDelete: Cascade)
  columnId     String
  label        String
  // "short_text" | "long_text" | "attachment" | "single_choice" | "multi_choice"
  type         String
  // JSON-encoded string[]; only used by the choice field types.
  options      String?
  // Only valid for short_text/long_text fields. At most one per column;
  // whenever this field's value is set, it is copied onto Card.title so the
  // title keeps showing even after the card leaves this column.
  isTitleField Boolean      @default(false)
  order        Int
  values       FieldValue[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([columnId, order])
}

// One card's value for one field definition. Only the column matching the
// field's type is populated (textValue for short/long text, choiceValue
// (JSON-encoded string[]) for single/multi choice, attachments for the
// attachment type — a single field can hold multiple files).
model FieldValue {
  id                String          @id @default(cuid())
  card              Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId            String
  fieldDefinition   FieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  fieldDefinitionId String
  textValue         String?
  choiceValue       String?
  attachments       Attachment[]
  updatedAt         DateTime        @updatedAt

  @@unique([cardId, fieldDefinitionId])
  @@index([cardId])
}
